    {
      "fullUrl": "urn:uuid:issue-P001-3",
      "resource": {
        "resourceType": "DetectedIssue",
        "status": "final",
        "patient": {
          "reference": "Patient/P001"
        },
        "severity": "high",
        "code": {
          "text": "bevacizumab + low-molecular-weight heparin (lmwh)"
        },
        "detail": "Bevacizumab increases the risk of thromboembolic events due to anti-angiogenic effects, while LMWH is an anticoagulant. Concurrent use may paradoxically increase bleeding risk (due to LMWH's anticoagulant effect) or thrombosis risk (due to bevacizumab's pro-thrombotic effects), depending on the balance between anticoagulation and vascular integrity.",
        "mitigation": [
          {
            "action": {
              "text": "Avoid concomitant use if possible. If required, closely monitor for signs of bleeding or thrombosis, and adjust LMWH dosing based on clinical response and coagulation parameters. Consult hematology/oncology for risk-benefit evaluation."
            }
          }
        ]
      }
    },
    {
      "fullUrl": "urn:uuid:issue-P001-6",
      "resource": {
        "resourceType": "DetectedIssue",
        "status": "final",
        "patient": {
          "reference": "Patient/P001"
        },
        "severity": "high",
        "code": {
          "text": "bevacizumab + valproate sodium"
        },
        "detail": "Bevacizumab may inhibit the metabolism of valproate sodium, leading to increased plasma concentrations of valproate and a heightened risk of valproate toxicity (e.g., encephalopathy, hepatotoxicity).",
        "mitigation": [
          {
            "action": {
              "text": "Avoid concomitant use if possible. If co-administration is necessary, closely monitor valproate levels and consider dose reduction of valproate. Consult a specialist for risk-benefit evaluation."
            }
          }
        ]
      }
    },
    {
      "fullUrl": "urn:uuid:issue-P001-16",
      "resource": {
        "resourceType": "DetectedIssue",
        "status": "final",
        "patient": {
          "reference": "Patient/P001"
        },
        "severity": "high",
        "code": {
          "text": "fluconazole + temozolomide"
        },
        "detail": "Fluconazole inhibits CYP2C9, the primary metabolic enzyme for temozolomide, leading to increased plasma concentrations of temozolomide and heightened risk of toxicity.",
        "mitigation": [
          {
            "action": {
              "text": "Avoid concomitant use of fluconazole and temozolomide. If antifungal therapy is required, consider alternative agents with minimal CYP2C9 inhibition (e.g., itraconazole, posaconazole) and monitor temozolomide levels if co-administration is unavoidable."
            }
          }
        ]
      }
    },
    {
      "fullUrl": "urn:uuid:issue-P001-17",
      "resource": {
        "resourceType": "DetectedIssue",
        "status": "final",
        "patient": {
          "reference": "Patient/P001"
        },
        "severity": "high",
        "code": {
          "text": "fluconazole + valproate sodium"
        },
        "detail": "Fluconazole inhibits hepatic metabolism of valproate sodium, potentially increasing valproate plasma concentrations and risk of toxicity (e.g., hepatotoxicity, encephalopathy).",
        "mitigation": [
          {
            "action": {
              "text": "Avoid concomitant use if possible. If required, closely monitor valproate levels and consider dose reduction of valproate sodium. Alternative antifungal agents (e.g., itraconazole) may be considered if feasible."
            }
          }
        ]
      }
    },
    {
      "fullUrl": "urn:uuid:issue-P001-20",
      "resource": {
        "resourceType": "DetectedIssue",
        "status": "final",
        "patient": {
          "reference": "Patient/P001"
        },
        "severity": "high",
        "code": {
          "text": "Lomustine + Temozolomide"
        },
        "detail": "Additive myelosuppression; both agents are alkylating",
        "mitigation": [
          {
            "action": {
              "text": "Requires dose reduction and close haematologic monitoring"
            }
          }
        ]
      }
    },
    {
      "fullUrl": "urn:uuid:issue-P001-21",
      "resource": {
        "resourceType": "DetectedIssue",
        "status": "final",
        "patient": {
          "reference": "Patient/P001"
        },
        "severity": "high",
        "code": {
          "text": "lomustine + valproate sodium"
        },
        "detail": "Lomustine inhibits the hepatic metabolism of valproate sodium, leading to increased plasma concentrations of valproate and a heightened risk of valproate toxicity, including fatal hepatotoxicity.",
        "mitigation": [
          {
            "action": {
              "text": "Avoid concomitant use of lomustine and valproate sodium. If co-administration is unavoidable, closely monitor valproate levels and consider dose reduction of valproate, but this combination is generally contraindicated due to the significant risk of severe toxicity."
            }
          }
        ]
      }
    },
    {
      "fullUrl": "urn:uuid:issue-P001-27",
      "resource": {
        "resourceType": "DetectedIssue",
        "status": "final",
        "patient": {
          "reference": "Patient/P001"
        },
        "severity": "high",
        "code": {
          "text": "temozolomide + valproate sodium"
        },
        "detail": "Valproate sodium inhibits carboxylesterase 1 (CES1), an enzyme involved in the metabolic activation of temozolomide, leading to increased plasma concentrations of temozolomide and potential toxicity.",
        "mitigation": [
          {
            "action": {
              "text": "Avoid concomitant use if possible. If co-administration is necessary, closely monitor for temozolomide-related toxicity (e.g., myelosuppression, neurotoxicity) and consider dose reduction of temozolomide. Alternative anticonvulsants (e.g., levetiracetam) may be preferred."
            }
          }
        ]
      }
